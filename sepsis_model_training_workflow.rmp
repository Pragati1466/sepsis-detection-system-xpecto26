        <parameter key="eliminate_zero_variance" value="true"/>
      </operator>
      
      <!-- Phase 4: Model Training & Balancing -->
      
      <!-- Task 4.1: SMOTE for class balancing -->
      <operator activated="true" class="smote" compatibility="9.10.001" expanded="true" height="82" name="SMOTE Balancing" width="90" x="1385" y="85">
        <parameter key="classify_label" value="Sepsis_3_Label"/>
        <parameter key="ratio" value="8.0"/>
        <parameter key="nearest_neighbors" value="5"/>
