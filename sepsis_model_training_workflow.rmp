      <operator activated="true" class="moving_average" compatibility="9.10.001" expanded="true" height="82" name="O2Sat 3-Hour StdDev" width="90" x="983" y="136">
        <parameter key="attribute_name" value="O2Sat"/>
        <parameter key="window_size" value="3"/>
