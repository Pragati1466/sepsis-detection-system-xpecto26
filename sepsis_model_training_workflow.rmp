          <parameter key="filters_list_entry" value="Age >= 18"/>
        </list>
        <parameter key="filter_type" value="include"/>
        <parameter key="include_special_attributes" value="true"/>
      </operator>
      
      <!-- Modified: Keep both sepsis and non-sepsis cases for model training -->
      <operator activated="true" class="generate_attributes" compatibility="9.10.001" expanded="true" height="82" name="Generate Sepsis-3 Labels" width="90" x="313" y="34">
        <list key="function_descriptions">
          <parameter key="Sepsis_3_Label" value="if(SepsisLabel == 1 &amp;&amp; Hour >= 6, 1, 0)"/>
          <parameter key="Hours_Before_Onset" value="if(SepsisLabel == 1, Hour, missing)"/>
        </list>
        <parameter key="keep_all" value="true"/>
      </operator>
      
      <!-- Remove the filter that only kept sepsis cases - we need both classes -->
      <operator activated="true" class="replace_missing_values" compatibility="9.10.001" expanded="true" height="82" name="Replace Missing Lab Values" width="90" x="447" y="34">
        <parameter key="return_preprocessing_model" value="false"/>
        <parameter key="create_view" value="false"/>
        <parameter key="attribute_filter_type" value="subset"/>
        <parameter key="attribute" value=""/>
        <parameter key="attributes" value="BaseExcess|HCO3|FiO2|pH|PaCO2|SaO2|AST|BUN|Alkalinephos|Calcium|Chloride|Creatinine|Bilirubin_direct|Glucose|Lactate|Magnesium|Phosphate|Potassium|Bilirubin_total|TroponinI|Hct|Hgb|PTT|WBC|Fibrinogen|Platelets"/>
