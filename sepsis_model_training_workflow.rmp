      </operator>
      
      <operator activated="true" class="generate_attributes" compatibility="9.10.001" expanded="true" height="82" name="Calculate SOFA Sub-scores" width="90" x="1117" y="85">
        <list key="function_descriptions">
          <parameter key="SOFA_Renal" value="if(is_missing(Creatinine), 0,
if(Creatinine &lt; 1.2, 0,
if(Creatinine &lt; 2.0, 1,
if(Creatinine &lt; 3.5, 2,
if(Creatinine &lt; 5.0, 3, 4)))))"/>
          <parameter key="PaO2_FiO2_Ratio" value="if(FiO2 > 0, PaCO2 * FiO2 / 21, missing)"/>
          <parameter key="SOFA_Respiratory" value="if(is_missing(PaO2_FiO2_Ratio), 0,
if(PaO2_FiO2_Ratio >= 400, 0,
if(PaO2_FiO2_Ratio >= 300, 1,
if(PaO2_FiO2_Ratio >= 200, 2,
if(PaO2_FiO2_Ratio >= 100, 3, 4)))))"/>
          <parameter key="SOFA_Cardiovascular" value="if(is_missing(MAP), 0,
if(MAP >= 70, 0,
if(MAP >= 50, 1,
if(MAP >= 30, 2, 3)))"/>
          <parameter key="SOFA_Total" value="SOFA_Renal + SOFA_Respiratory + SOFA_Cardiovascular"/>
        </list>
        <parameter key="keep_all" value="true"/>
      </operator>
      
      <operator activated="true" class="normalize" compatibility="9.10.001" expanded="true" height="82" name="Normalize Features" width="90" x="1251" y="85">
        <parameter key="return_preprocessing_model" value="false"/>
        <parameter key="create_view" value="false"/>
