      <!-- Task 4.3 & 4.4: Cross-Validation with Multiple Models -->
      
      <!-- Gradient Boosted Trees Model -->
      <operator activated="true" class="cross_validation" compatibility="9.10.001" expanded="true" height="145" name="Cross Validation - Gradient Boosted Trees" width="90" x="1653" y="34">
