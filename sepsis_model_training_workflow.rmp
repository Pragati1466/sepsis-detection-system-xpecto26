        <parameter key="parameter_parameter" value=""/>
        <parameter key="condition_class" value="attribute_value_filter"/>
        <parameter key="condition_parameter" value="Age"/>
        <parameter key="condition_value" value=">= 18"/>
        <parameter key="invert_filter" value="false"/>
