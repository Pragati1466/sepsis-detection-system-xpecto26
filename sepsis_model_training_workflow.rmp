      <!-- Phase 3: Feature Engineering -->
      <operator activated="true" class="generate_attributes" compatibility="9.10.001" expanded="true" height="82" name="Calculate Shock Index" width="90" x="715" y="34">
        <list key="function_descriptions">
          <parameter key="Shock_Index" value="if(SBP > 0, HR / SBP, missing)"/>
