            <process expanded="true">
              <operator activated="true" class="gradient_boosted_trees" compatibility="9.10.001" expanded="true" height="82" name="Gradient Boosted Trees" width="90" x="45" y="34">
                <parameter key="number_of_trees" value="100"/>
                <parameter key="max_depth" value="5"/>
